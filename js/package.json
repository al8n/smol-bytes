{
  "name": "smol-bytes",
  "version": "0.1.0",
  "type": "module",
  "description": "High-performance, clone-efficient byte buffers for JavaScript/TypeScript",
  "license": "MIT OR Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/al8n/smol-bytes"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./shared": {
      "types": "./dist/shared.d.ts",
      "import": "./dist/shared.js"
    },
    "./compact": {
      "types": "./dist/compact.d.ts",
      "import": "./dist/compact.js"
    }
  },
  "files": [
    "dist/",
    "pkg/package.json",
    "pkg/smol_bytes.d.ts",
    "pkg/smol_bytes.js",
    "pkg/smol_bytes_bg.js",
    "pkg/smol_bytes_bg.wasm",
    "pkg/smol_bytes_bg.wasm.d.ts"
  ],
  "scripts": {
    "build:wasm": "cd .. && wasm-pack build smol-bytes --target bundler --out-dir ../js/pkg -- --features wasm",
    "build:js": "tsc",
    "build": "npm run build:wasm && npm run build:js",
    "test": "vitest run && npm run test:package",
    "test:package": "node scripts/verify-package.mjs"
  },
  "devDependencies": {
    "typescript": "^5.0",
    "vite-plugin-top-level-await": "^1.6.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^3.0"
  }
}
